# Copy to .env.local for local dev, or set these in Vercel dashboard for production

# Firebase (set all of these in Vercel → Settings → Environment Variables)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini — optional, leave blank to rely solely on backend OpenRouter
VITE_GEMINI_API_KEY=

# Your Render backend URL (set after deploying server/)
VITE_API_URL=https://your-safenet-backend.onrender.com
