# Copy this to .env and fill in your keys
# These are SERVER-SIDE only — never committed to git

OPENROUTER_API_KEY=sk-or-v1-your-key-here
WEATHER_API_KEY=your-openweathermap-key-here

# Your Vercel frontend URL (set after deploying frontend)
# Used for CORS and HTTP-Referer headers
FRONTEND_URL=https://your-safenet-app.vercel.app

# Render sets PORT automatically — don't change this
PORT=3001
